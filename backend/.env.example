# --- Django Settings ---
DJANGO_SECRET_KEY=django-insecure-dev-only-secret-key-12345
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Set DB_ENGINE to 'sqlite' for zero-config local development
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# --- CORS & Security ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
