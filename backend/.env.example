# --- Django Settings ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=django-insecure-dev-only-secret-key-12345
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Django admin (/admin/) — set false in production unless you explicitly need it
# DJANGO_ADMIN_ENABLED=false

# Max CSV upload size for student import (bytes; default 5242880 = 5MB)
# STUDENT_CSV_IMPORT_MAX_BYTES=5242880

# Password reset (link in email points to frontend)
# FRONTEND_BASE_URL=http://localhost:3000
# FRONTEND_PASSWORD_RESET_PATH=/reset-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
# Optional: comma-separated allowed hosts for homework attachment URLs (HTTPS only still required)
# HOMEWORK_ATTACHMENT_ALLOWED_HOSTS=cdn.example.com

# --- Database ---
# Set DATABASE_URL for PostgreSQL, or leave unset to use SQLite
# DATABASE_URL=postgres://scoolerp_user:scoolerp_password@localhost:5432/scoolerp_db

# --- CORS & Security ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Online payments (Razorpay) — optional; leave unset until you go live ---
# ONLINE_PAYMENTS_ENABLED=true
# RAZORPAY_KEY_ID=rzp_test_xxxx
# RAZORPAY_KEY_SECRET=xxxx
# RAZORPAY_WEBHOOK_SECRET=xxxx   # Dashboard → Webhooks → secret; required to verify signatures

# --- Storage (DigitalOcean Spaces) ---
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_ENDPOINT_URL=https://blr1.digitaloceanspaces.com
